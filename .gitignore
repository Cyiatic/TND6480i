# Commercial ROMs, generated candidates, and save data stay local.
*.z64
*.n64
*.v64
*.rom
*.bin
*.eep
*.eeprom
*.sav
*.sra
*.fla

# Patch/output blobs can be regenerated locally.
*.xdelta
*.vcdiff
*.ips
*.bps

# Emulator and tool noise.
*.log
*.stdout.txt
*.stderr.txt
*.tmp
tools/
reports/hardware_*_stdout_*.txt
reports/hardware_*_stderr_*.txt
reports/hardware_*_stdout.txt
reports/hardware_*_stderr.txt
reports/hardware_*listener*.txt
reports/hardware_*_summary*.json
reports/dump_after_reset_*.bin
reports/dump_after_reset_*.json
__pycache__/
.pytest_cache/

# Local artifact staging.
artifacts/analogue_test/*
artifacts/diagnostics/*
artifacts/roms/*
artifacts/generated/*
artifacts/release/*
artifacts/reports/*
artifacts/scratch/*
artifacts/tmp/*
!artifacts/analogue_test/README.md
!artifacts/roms/.gitkeep
!artifacts/generated/.gitkeep
!artifacts/tmp/.gitkeep

# Keep already tracked curated diagnostics, but ignore accidental bulk captures.
diagnostics/bulk/
diagnostics/aux/
diagnostics/captures/**/*.bmp
diagnostics/captures/**/*.jpg
diagnostics/captures/**/*.jpeg
diagnostics/captures/**/*.png
diagnostics/captures/**/*.avi
diagnostics/captures/**/*.mkv
diagnostics/captures/**/*.mov
diagnostics/captures/**/*.mp4
diagnostics/captures/**/*.mpg
diagnostics/captures/**/*.webm
diagnostics/captures/**/frames/
diagnostics/captures/**/keyframes/
diagnostics/**/*.json
diagnostics/**/*.txt
diagnostics/routes/*.events
diagnostics/framebuffers/
diagnostics/sc64/

# Generated analysis reports are useful locally, but should be curated before commit.
reports/**/*.json
reports/**/*.csv
reports/**/*.txt
reports/measurement/**/*_frames/
reports/measurement/**/*.png
